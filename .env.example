# Core data sources
DIA_AGENT_GRAPH_JSON_PATH="dataset/graph.json"
DIA_AGENT_GUIDELINE_PDF_PATHS="dataset/中国糖尿病防治指南（2024版）.pdf"

# Neo4j
DIA_AGENT_NEO4J_URI="bolt://localhost:7687"
DIA_AGENT_NEO4J_USER="neo4j"
DIA_AGENT_NEO4J_PASSWORD=""
DIA_AGENT_NEO4J_DATABASE="neo4j"

# RAG / retrieval
DIA_AGENT_CHROMA_PERSIST_DIR="data/chroma"
DIA_AGENT_CHROMA_COLLECTION="dia_guidelines"
DIA_AGENT_EMBEDDING_MODEL="moka-ai/m3e-base"
DIA_AGENT_RETRIEVAL_K="4"
DIA_AGENT_DEFAULT_RAG_QUERY="1型糖尿病 肾功能不全 用药"

# LLM
DIA_AGENT_LLM_BASE_URL="https://your-llm-endpoint/v1"
DIA_AGENT_LLM_API_KEY="your-api-key"
DIA_AGENT_LLM_MODEL="gpt-5.4"
DIA_AGENT_LLM_WIRE_API="responses"
DIA_AGENT_LLM_TEMPERATURE="0.2"
DIA_AGENT_LLM_TIMEOUT_SEC="60"

# Vision model
DIA_AGENT_VISION_BASE_URL=""
DIA_AGENT_VISION_API_KEY=""
DIA_AGENT_VISION_MODEL="Qwen/Qwen2-VL-7B-Instruct"
DIA_AGENT_VISION_WIRE_API="chat_completions"

# Workflow
DIA_AGENT_MAX_REASONER_RETRIES="3"
DIA_AGENT_REACT_MAX_STEPS="4"

# API server
DIA_AGENT_API_TITLE="Dia-Agent API"
DIA_AGENT_API_VERSION="0.1.0"
DIA_AGENT_API_HOST="0.0.0.0"
DIA_AGENT_API_PORT="8000"
DIA_AGENT_API_RELOAD="false"

# UI
DIA_AGENT_UI_PAGE_TITLE="Dia-Agent"
DIA_AGENT_UI_LAYOUT="wide"
DIA_AGENT_UI_APP_TITLE="Dia-Agent: Guardrail-First 专病智能体"
DIA_AGENT_UI_DEFAULT_RAW_INPUT='{"indicators": {"eGFR": 25, "HbA1c": 9.3}, "diseases": ["糖尿病酮症酸中毒"], "current_drugs": ["盐酸二甲双胍片 (普通片/缓释片)"]}'
DIA_AGENT_UI_DEFAULT_HISTORY_TEXT=""
DIA_AGENT_UI_UPLOAD_DIR="data/uploads"
